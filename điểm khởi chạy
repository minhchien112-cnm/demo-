def main():
    print_banner()
    print("  ⏳ Đang kiểm tra dependencies...")
    check_dependencies()
    print("  ✅ Tất cả thư viện OK!\n")

    check_known_faces()

    print("  🚀 Đang khởi động giao diện...\n")

    import tkinter as tk
    from gui_app import FaceAttendanceApp

    root = tk.Tk()
    app = FaceAttendanceApp(root)
    root.mainloop()


if __name__ == "__main__":
    main()
