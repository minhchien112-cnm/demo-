    # ══════════════════════════════════════════════════
    def _make_button(self, parent, text, color, command, width=12):
        btn = tk.Button(
            parent, text=text, command=command,
            bg=color, fg="white",
            font=config.FONTS["body_bold"],
            relief="flat", bd=0, cursor="hand2",
            padx=12, pady=6, width=width,
            activebackground=color, activeforeground="white"
        )
        btn.bind("<Enter>", lambda e: btn.config(bg=self._lighten(color)))
        btn.bind("<Leave>", lambda e: btn.config(bg=color))
        return btn

    def _lighten(self, hex_color):
        """Làm sáng màu hex một chút khi hover."""
        try:
            r = int(hex_color[1:3], 16)
            g = int(hex_color[3:5], 16)
            b = int(hex_color[5:7], 16)
            r = min(255, r + 30)
            g = min(255, g + 30)
            b = min(255, b + 30)
            return f"#{r:02x}{g:02x}{b:02x}"
        except Exception:
            return hex_color

    def _add_card_border(self, widget):
        widget.config(highlightbackground=config.COLORS["border"],
                      highlightthickness=1)

    def _set_status(self, msg):
        self.root.after(0, lambda: self.status_label.config(text=msg))

    def _update_datetime(self):
        from datetime import datetime
        now = datetime.now().strftime("%A, %d/%m/%Y  %H:%M:%S")
        self.datetime_label.config(text=now)
        self.root.after(1000, self._update_datetime)

    def _update_db_count(self, count=None):
        if count is None:
            info = get_known_faces_info()
            count = len(info)
        self.root.after(0, lambda: self.stat_db_label.config(text=str(count)))

    def _flash_success(self):
        """Hiệu ứng flash xanh lá khi điểm danh thành công."""
        original_bg = config.COLORS["bg_card"]
        flash_bg = config.COLORS["success_bg"]

        def _do_flash(times=3, on=True):
            if times <= 0:
                self.stat_total_label.config(bg=original_bg)
                return
            bg = flash_bg if on else original_bg
            self.stat_total_label.config(bg=bg)
            self.root.after(200, lambda: _do_flash(times - 1, not on))

        _do_flash()

    # ══════════════════════════════════════════════════
    #  CLEANUP
    # ══════════════════════════════════════════════════
    def _on_close(self):
        self.camera_running = False
        if self.cap:
            self.cap.release()
        self.root.destroy()
