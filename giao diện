    def _export_excel(self):
        path = self.attendance_mgr.export_to_excel()
        if path:
            messagebox.showinfo("Xuất Excel thành công",
                                f"File đã được lưu tại:\n{path}")
            import subprocess
            subprocess.Popen(["explorer", "/select,", path])
        else:
            messagebox.showwarning("Thông báo",
                                   "Không có dữ liệu điểm danh hôm nay để xuất!")

    def _open_attendance_folder(self):
        import subprocess
        subprocess.Popen(["explorer", config.ATTENDANCE_DIR])

    # ══════════════════════════════════════════════════
