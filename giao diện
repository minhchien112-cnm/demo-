    # ══════════════════════════════════════════════════
    #  CAMERA LOGIC
    # ══════════════════════════════════════════════════
    def _toggle_camera(self):
        if self.camera_running:
            self._stop_camera()
        else:
            self._start_camera()

    def _start_camera(self):
        self.cap = cv2.VideoCapture(config.CAMERA_INDEX)
        if not self.cap.isOpened():
            messagebox.showerror("Lỗi", "Không thể mở camera!\nKiểm tra lại thiết bị.")
            return

        self.cap.set(cv2.CAP_PROP_FRAME_WIDTH, 1280)
        self.cap.set(cv2.CAP_PROP_FRAME_HEIGHT, 720)
        self.camera_running = True
        self.toggle_cam_btn.config(
            text="⏹  Tắt Camera",
            bg=config.COLORS["accent_red"]
        )
        self.cam_status_dot.config(fg=config.COLORS["accent_green"])
        self._set_status("🎥 Camera đang chạy...")

        # Thread nhận frame từ camera
        self._capture_thread = threading.Thread(
            target=self._capture_loop, daemon=True
        )
        self._capture_thread.start()

        # Thread nhận diện khuôn mặt
        self._recog_thread = threading.Thread(
            target=self._recognition_loop, daemon=True
        )
        self._recog_thread.start()

        self._update_camera_display()

    def _stop_camera(self):
        self.camera_running = False
        if self.cap:
            self.cap.release()
            self.cap = None
        self.camera_label.config(
            image="",
            text="Camera đã tắt\n\nNhấn 'Bật Camera' để bắt đầu lại",
            font=config.FONTS["heading"],
            fg=config.COLORS["text_muted"]
        )
        self.toggle_cam_btn.config(
            text="▶  Bật Camera",
            bg=config.COLORS["accent_green"]
        )
        self.cam_status_dot.config(fg=config.COLORS["text_muted"])
        self._set_status("⏹ Camera đã tắt")
        self.fps_label.config(text="FPS: —")

    def _capture_loop(self):
        """Thread đọc frame từ camera."""
        while self.camera_running:
            if self.cap is None:
                break
            ret, frame = self.cap.read()
            if not ret:
                break
            frame = cv2.flip(frame, 1)  # Mirror effect
            if not self.frame_queue.full():
                self.frame_queue.put(frame)
        print("[INFO] Capture loop kết thúc.")

    def _recognition_loop(self):
        """Thread nhận diện khuôn mặt (chạy nền)."""
        interval = config.RECOGNITION_INTERVAL
        local_count = 0
        while self.camera_running:
            try:
                frame = self.frame_queue.get(timeout=0.5)
            except queue.Empty:
                continue

            local_count += 1
            if local_count % interval != 0:
                continue

            results = recognize_faces(frame, self.known_encodings, self.known_names)

            for r in results:
                if r["name"] != "Unknown":
                    att_result = self.attendance_mgr.mark_attendance(r["name"])
                    if att_result["is_new"]:
                        self.result_queue.put({
                            "type": "new_attendance",
                            "name": r["name"],
                            "message": att_result["message"],
                        })

            if not self.result_queue.full():
                self.result_queue.put({"type": "frame_result", "results": results})

    def _update_camera_display(self):
        """Cập nhật hiển thị camera (chạy trên main thread)."""
        if not self.camera_running:
            return

        try:
            frame = self.frame_queue.get_nowait()

            # Tính FPS
            self.frame_count += 1
            elapsed = time.time() - self.fps_start
            if elapsed >= 1.0:
                self.fps = self.frame_count / elapsed
                self.frame_count = 0
                self.fps_start = time.time()
                self.fps_label.config(text=f"FPS: {self.fps:.1f}")

            # Vẽ kết quả nhận diện nếu có
            if hasattr(self, "_last_recognition_results"):
                frame = draw_face_boxes(frame, self._last_recognition_results)
                frame = add_overlay_info(frame, self.fps,
                                        len(self._last_recognition_results))

            # Resize để fit panel
            frame_rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
            cam_w = self.camera_label.winfo_width() or config.CAMERA_WIDTH
            cam_h = self.camera_label.winfo_height() or config.CAMERA_HEIGHT
            img = Image.fromarray(frame_rgb)
            img.thumbnail((cam_w, cam_h), Image.LANCZOS)
            photo = ImageTk.PhotoImage(img)
            self.camera_label.config(image=photo, text="")
            self.camera_label.image = photo

        except queue.Empty:
            pass

        self.root.after(33, self._update_camera_display)  # ~30 FPS UI

    # ══════════════════════════════════════════════════
    #  RESULT CONSUMER
    # ══════════════════════════════════════════════════
    def _start_result_consumer(self):
        """Xử lý kết quả từ thread nhận diện."""
        def consume():
            while True:
                try:
                    result = self.result_queue.get_nowait()
                    rtype = result.get("type")

                    if rtype == "frame_result":
                        self._last_recognition_results = result["results"]
                        count = len(result["results"])
                        if count > 0:
                            self._set_status(
                                f"👁 Đang nhận diện {count} khuôn mặt..."
                            )

                    elif rtype == "new_attendance":
                        self._set_status(f"✅ {result['message']}")
                        self._refresh_attendance_table()
                        self._flash_success()

                except queue.Empty:
                    pass
                time.sleep(0.1)

        t = threading.Thread(target=consume, daemon=True)
        t.start()

    # ══════════════════════════════════════════════════
    #  FACE DATA
    # ══════════════════════════════════════════════════
    def _load_face_data(self):
        """Tải dữ liệu khuôn mặt (ưu tiên cache)."""
        def _load():
            self._set_status("⏳ Đang tải dữ liệu khuôn mặt...")
            enc, names = load_encodings()
            if not enc:
                enc, names = load_known_faces()
                if enc:
                    save_encodings(enc, names)
            self.known_encodings = enc
            self.known_names = names
            count = len(set(names))
            self._update_db_count(count)
            if count:
                self._set_status(f"✅ Đã tải {count} người trong cơ sở dữ liệu")
            else:
                self._set_status(
                    "⚠️ Chưa có dữ liệu khuôn mặt — Thêm ảnh vào thư mục known_faces/"
                )

        threading.Thread(target=_load, daemon=True).start()

    def _reload_faces(self):
        """Tải lại dữ liệu khuôn mặt từ thư mục (bỏ qua cache)."""
        def _reload():
            self._set_status("🔄 Đang tải lại dữ liệu khuôn mặt...")
            enc, names = load_known_faces()
            if enc:
                save_encodings(enc, names)
            self.known_encodings = enc
            self.known_names = names
            count = len(set(names))
            self._update_db_count(count)
            self._set_status(f"✅ Đã tải lại: {count} người")
            messagebox.showinfo("Thành công",
                                f"Đã tải lại {count} người từ known_faces/")

        threading.Thread(target=_reload, daemon=True).start()

    # ══════════════════════════════════════════════════
    #  ATTENDANCE TABLE
    # ══════════════════════════════════════════════════
    def _refresh_attendance_table(self):
        """Cập nhật bảng điểm danh."""
        records = self.attendance_mgr.get_today_attendance()

        for item in self.tree.get_children():
            self.tree.delete(item)

        for i, r in enumerate(records):
            tag = "even" if i % 2 == 0 else "odd"
            self.tree.insert("", tk.END, values=(
                r["stt"],
                r["display_name"],
                r["time"],
                r["status"],
            ), tags=(tag,))

        total = len(records)
        self.stat_total_label.config(text=str(total))

        # Scroll xuống dòng mới nhất
        children = self.tree.get_children()
        if children:
            self.tree.see(children[-1])

